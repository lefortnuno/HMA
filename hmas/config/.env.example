# MODELE de configuration backend — copier vers config/.env et remplir.
# EN PRODUCTION (Render) : definir ces variables dans le dashboard Render
# (Environment > Environment Variables), PAS dans un fichier committe.

# Secret JWT : longue chaine aleatoire (ex: `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`)
TOKEN_SECRET = "CHANGE_MOI"

IP_HOST = "0.0.0.0"
PORT = 5103

xADMIN = 1
xUSER = 0

# Origines autorisees pour CORS (domaines frontend, separes par des virgules).
# Exemple : CORS_ORIGINS = "https://mon-app.vercel.app,http://localhost:3000"
CORS_ORIGINS = ""

OFFLINE_DB_HOST = "localhost"
OFFLINE_DB_NAME = "hma"
OFFLINE_DB_USER = "root"
OFFLINE_DB_MDP = ""

SUN_DB_HOST = ""
SUN_DB_NAME = ""
SUN_DB_USER = ""
SUN_DB_MDP = ""
